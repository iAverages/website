{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "website",
	"main": "@tanstack/solid-start/server-entry",
	"compatibility_date": "2025-06-14",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./public"
	},
	"observability": {
		"enabled": true
	}

